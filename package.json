{
  "name": "@aegis-cli/infra-sdk",
  "version": "0.2.0",
  "description": "Plugin SDK for aegis-cli infrastructure backends",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rtmx-ai/aegis-infra-sdk"
  },
  "homepage": "https://github.com/rtmx-ai/aegis-infra-sdk",
  "bugs": {
    "url": "https://github.com/rtmx-ai/aegis-infra-sdk/issues"
  },
  "keywords": [
    "aegis",
    "aegis-cli",
    "plugin-sdk",
    "infrastructure",
    "compliance",
    "pulumi",
    "cloud-provider"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "aegis-ci-check": "dist/security/ci-compliance-cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./domain": "./dist/domain/types.js",
    "./ports": "./dist/domain/ports.js",
    "./protocol": "./dist/protocol/events.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --check 'src/**/*.ts'",
    "format:fix": "prettier --write 'src/**/*.ts'",
    "test": "vitest run",
    "test:unit": "vitest run src/",
    "precommit": "npm run format && npm run lint && npm run build && npm run test:unit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
